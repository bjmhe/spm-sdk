{
  "name": "@jd/spm-sdk",
  "version": "3.0.3",
  "description": "The SPM SDK for JD.com",
  "keywords": [
    "package",
    "preset",
    "typescript",
    "vite",
    "vite-plus"
  ],
  "license": "MIT",
  "author": "Benjamin He <hi@bjmhe.me>",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./h5": "./dist/h5.js",
    "./jdmp": "./dist/jdmp.js",
    "./jdrn": "./dist/jdrn.js",
    "./pc": "./dist/pc.js",
    "./tn": "./dist/tn.js",
    "./wxmp": "./dist/wxmp.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "release": "bumpp",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@bjmhe/automd": "^0.0.7",
    "@bjmhe/bjmhe": "^1.0.2",
    "@bjmhe/viteplus-preset": "^2.0.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "^4.1.7",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vite-plus": "^0.1.20"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "pnpm@11.4.0"
}
